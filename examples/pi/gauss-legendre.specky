|< sqrt2 <= 2.0 ^ 0.5

|< a <= 1.0
|< b <= 1.0 \ §sqrt2
|< p <= 1
|< t <= 0.25

|< i <= 0

[<] loop
    |< i + 1

    |< an <= §a

    |< a + §b \ 2.0
    |< b * §an ^ 0.5
    |< diff_sq <= §an - §a ^ 2.0
    |< p_diff <= §p * §diff_sq
    |< t - §p_diff
    |< p * 2

    |< pi <= §a + §b ^ 2.0 \ 4.0 \ §t {%} ?
[>] loop
